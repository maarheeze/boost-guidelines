{
  "name": "maarheeze/boost-guidelines",
  "description": "laravel boost integration for .ai guidelines",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "illuminate/support": "^11.0|^12.0|^13.0",
    "laravel/boost": "^2.0"
  },
  "require-dev": {
    "maarheeze/phpcs": "^1.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Maarheeze\\BoostGuidelines\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Maarheeze\\BoostGuidelines\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Maarheeze\\BoostGuidelines\\BoostGuidelinesServiceProvider"
      ],
      "aliases": {
        "Guidelines": "Maarheeze\\BoostGuidelines\\Facades\\Guidelines"
      }
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
