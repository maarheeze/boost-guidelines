{
  "name": "maarheeze/boost-guidelines",
  "description": "Boost integration for .ai guidelines",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "laravel/framework": "^11.0|^12.0|^13.0",
    "laravel/boost": "^1.0"
  },
  "require-dev": {
    "maarheeze/phpcs": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Maarheeze\\BoostGuidelines\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Maarheeze\\BoostGuidelines\\BoostGuidelinesServiceProvider"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
